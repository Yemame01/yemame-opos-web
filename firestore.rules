rules_version = '2';

// Yemame OPOS licensing/store Firestore rules.
//
// Architecture (mirrors yemame-pos): each buyer's data is NESTED under their own
// account; global mirrors exist only for server-side key lookup / admin. Config
// (pricing) lives in a central admin-config doc.
//
//   users/{uid}                      — buyer profile (owner read/write)
//   users/{uid}/licenses/{id}        — the buyer's licenses (owner read)
//   users/{uid}/payments/{ref}       — the buyer's purchase history (owner read)
//   licenses/{id}                    — GLOBAL MIRROR (server-write; owner may read own)
//   licenses/{id}/activations/{id}   — activation audit (server-write)
//   payments/{ref}                   — GLOBAL MIRROR / audit (server only)
//   adminConfig/general              — pricing + store config (public read, admin write)
//   adminLogs/** , rateLimits/**     — server only
//
// All money- and license-bearing writes go through Cloud Functions (Admin SDK
// bypasses these rules). Clients get LEAST privilege.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    // ---- Pricing + store config: public read (store needs prices pre-login),
    //      admin-only writes (Hub writes via Admin SDK, which bypasses rules;
    //      the `false` keeps every client out). ----
    match /adminConfig/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // ---- Users: a buyer owns their profile + nested licenses & payments. ----
    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid);
      allow delete: if false;

      // The buyer's licenses (canonical copy). Written by Cloud Functions.
      match /licenses/{licenseId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      // The buyer's purchase history. Written by the webhook (Admin SDK).
      match /payments/{reference} {
        allow read: if isOwner(uid);
        allow write: if false;
      }
    }

    // ---- Global license mirror: owner may read their own; writes server-only.
    //      Exists so activation can find a license by key without the uid. ----
    match /licenses/{licenseId} {
      allow read: if signedIn()
        && resource.data.ownerUid == request.auth.uid;
      allow write: if false;

      match /activations/{activationId} {
        allow read: if signedIn()
          && get(/databases/$(database)/documents/licenses/$(licenseId)).data.ownerUid == request.auth.uid;
        allow write: if false;
      }
    }

    // ---- Global payments mirror (audit): closed to clients. ----
    match /payments/{reference} {
      allow read, write: if false;
    }

    // ---- Admin logs + rate-limit counters: server-only. ----
    // Set a Firestore TTL policy on `rateLimits.expireAt` to auto-clean windows.
    match /adminLogs/{document=**} {
      allow read, write: if false;
    }
    match /rateLimits/{doc} {
      allow read, write: if false;
    }
  }
}
